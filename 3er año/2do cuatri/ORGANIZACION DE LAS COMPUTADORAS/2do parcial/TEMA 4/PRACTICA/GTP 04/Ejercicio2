.data
	arreglo: .word 5,2
	cantidad: .word 2
	
.text
.globl main
main:
	la t0, arreglo
	la t3, cantidad
	lw a2,0(t3)
	addi t2,x0,0 # contador
	addi t5,x0,0 # sumador
	beq a2,x0,fin_zero
	ret
loop:
	
	beq a2,t2,fin
	
	slli t6,t2,2
	add t4,t0,t6
	lw t1,0(t4)
	
	add t5,t5,t1
	addi t2,t2,1
	j loop
	
fin:
	div a0,t5,a2 # parte entera
	rem a1,t5,a2 # resto de la division
	ret
	
fin_zero:
	addi a0,x0,0
	addi a1,x0,0
	ret
	