.data
n: .word 3
resultado: .word 0

.text
.globl main
main:
    la   t0, n
    lw   a0, 0(t0)       # a0 = n

    li   a1, 0           # acumulador
    li   t6, 0           # cantidad de impares sumados
    li   t2, 1           # impar actual

loop:
    beq  t6, a0, fin
    add  a1, a1, t2      # sumo el impar actual
    addi t2, t2, 2       # prˇximo impar
    addi t6, t6, 1
    j    loop

fin:
    la   t3, resultado
    sw   a1, 0(t3)
    ecall